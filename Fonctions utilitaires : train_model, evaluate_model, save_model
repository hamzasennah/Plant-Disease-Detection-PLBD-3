def save_model(model, name):
    torch.save(model.state_dict(), f'{name}.pth')
    serializable = {k: v.cpu().numpy().tolist() for k,v in model.state_dict().items()}
    with open(f'{name}.json','w') as f: json.dump(serializable, f)
    print(f'✅ Sauvegardé : {name}.pth & {name}.json')


